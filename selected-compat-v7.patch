+func convertClaudeToolChoiceToOpenAI(choice any) any {
+	if choice == nil {
+		return nil
+	}
+	var tc dto.ClaudeToolChoice
+	if typed, ok := choice.(dto.ClaudeToolChoice); ok {
+		tc = typed
+	} else if typed, ok := choice.(*dto.ClaudeToolChoice); ok && typed != nil {
+		tc = *typed
+	} else {
+		parsed, err := common.Any2Type[dto.ClaudeToolChoice](choice)
+		if err != nil {
+			return choice
+		}
+		tc = parsed
+	}
+	switch strings.TrimSpace(tc.Type) {
+	case "auto", "none":
+		return tc.Type
+	case "any":
+		return "required"
+	case "tool":
+		name := strings.TrimSpace(tc.Name)
+		if name == "" {
+			return "required"
+		}
+		return map[string]any{"type": "function", "function": map[string]any{"name": name}}
+	default:
+		return choice
+	}
+}
