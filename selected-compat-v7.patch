+  align-items: center;
+  gap: 0.45rem;
+  padding: 0.55rem 0.95rem;
+  border-top: 1px solid var(--iz-line);
+  background: var(--iz-surface);
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  color: var(--iz-fg-muted);
+}
+.iz-code-foot-dot {
+  width: 5px;
+  height: 5px;
+  border-radius: 999px;
+  background: #22c55e;
+}
+
+/* ── CLOSING ── */
+.iz-closing {
+  position: relative;
+  padding: 7rem 1.25rem 8rem;
+  border-top: 1px solid var(--iz-line);
+  overflow: hidden;
+  isolation: isolate;
+}
+.iz-closing-bg,
+.iz-closing-grid {
+  position: absolute;
+  inset: 0;
+  pointer-events: none;
+}
+.iz-closing-bg {
+  background: radial-gradient(
+    80% 80% at 50% 50%,
+    color-mix(in oklab, var(--foreground) 8%, transparent),
+    transparent 70%
+  );
+  z-index: -2;
+}
+.iz-closing-grid {
+  background-image:
+    linear-gradient(to right, var(--iz-line) 1px, transparent 1px),
+    linear-gradient(to bottom, var(--iz-line) 1px, transparent 1px);
+  background-size: 48px 48px;
+  mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 70%);
+  -webkit-mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 70%);
+  opacity: 0.55;
+  z-index: -1;
+}
+.iz-closing-inner {
+  max-width: 40rem;
+  margin: 0 auto;
+  text-align: center;
+}
+.iz-closing-kicker {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.5rem;
+  padding: 0.3rem 0.7rem;
+  border: 1px solid var(--iz-line);
+  border-radius: 999px;
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+  color: var(--iz-fg-soft);
+  background: var(--iz-surface);
+}
+.iz-closing-kicker-dot {
+  width: 5px;
+  height: 5px;
+  border-radius: 999px;
+  background: var(--iz-fg);
+}
+.iz-closing-title {
+  margin: 1rem 0 0.85rem;
+  font-size: clamp(1.85rem, 3.2vw, 2.65rem);
+  line-height: 1.12;
+  letter-spacing: -0.025em;
+  font-weight: 600;
+  color: var(--iz-fg);
+}
+.iz-closing-sub {
+  margin: 0 0 1.5rem;
+  font-size: 0.975rem;
+  line-height: 1.65;
+  color: var(--iz-fg-muted);
+}
+.iz-closing-cta {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.65rem;
+}
+
+/* ── Keyframes ── */
+@keyframes iz-rise {
+  to {
+    transform: translateY(0);
+  }
+}
+@keyframes iz-fade-in {
+  from {
+    opacity: 0;
+    transform: translateY(8px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+@keyframes iz-eyebrow-in {
+  from {
+    opacity: 0;
+    transform: translateY(-8px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+@keyframes iz-pulse {
+  0%,
+  100% {
+    opacity: 1;
+  }
+  50% {
+    opacity: 0.5;
+  }
+}
+@keyframes iz-slot {
+  from {
+    transform: translateY(120%);
+    opacity: 0;
+  }
+  to {
+    transform: translateY(0);
+    opacity: 1;
+  }
+}
+@keyframes iz-scroll {
+  0% {
+    transform: translateY(-100%);
+  }
+  50% {
+    transform: translateY(120%);
+  }
+  100% {
+    transform: translateY(120%);
+  }
+}
+
+@media (max-width: 640px) {
+  .iz-hero {
+    padding-top: 6rem;
+    min-height: auto;
+  }
+  .iz-hero-base-frame {
+    flex-wrap: wrap;
+    gap: 0.4rem;
+  }
+  .iz-hero-base-url {
+    max-width: 100%;
+  }
+  .iz-hero-base-mount {
+    min-width: 0;
+  }
+  .iz-hero-stats {
+    gap: 0.85rem;
+    padding: 0.55rem 0.95rem;
+  }
+  .iz-pillar-cell {
+    border-right: none !important;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .iz-hero-title-word,
+  .iz-hero-title-accent,
+  .iz-hero-title-glow,
+  .iz-hero-eyebrow,
+  .iz-hero-sub,
+  .iz-hero-base,
+  .iz-hero-cta,
+  .iz-hero-stats,
+  .iz-hero-base-mount-path,
+  .iz-hero-scroll span,
+  .iz-hero-dot,
+  .iz-endpoint-status-dot {
+    animation: none !important;
+    transform: none !important;
+    opacity: 1 !important;
+  }
+}
