+                  </TableHead>
+                  <TableHead className='text-right'>
+                    <SortableHeader
+                      label='Tokens'
+                      align='right'
+                      active={modelSort.key === 'tokens'}
+                      direction={modelSort.direction}
+                      onClick={() => setModelSort(nextSortState(modelSort, 'tokens'))}
+                    />
+                  </TableHead>
+                  <TableHead className='text-right'>
+                    <SortableHeader
+                      label='Cost'
+                      align='right'
+                      active={modelSort.key === 'cost'}
+                      direction={modelSort.direction}
+                      onClick={() => setModelSort(nextSortState(modelSort, 'cost'))}
+                    />
+                  </TableHead>
