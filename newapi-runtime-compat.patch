+		parsed, err := common.Any2Type[dto.ClaudeToolChoice](choice)
+		if err != nil {
+			return choice
+		}
+		tc = parsed
+	}
+	switch strings.TrimSpace(tc.Type) {
+	case "auto", "none":
+		return tc.Type
+	case "any":
+		return "required"
+	case "tool":
+		name := strings.TrimSpace(tc.Name)
+		if name == "" {
+			return "required"
+		}
+		return map[string]any{"type": "function", "function": map[string]any{"name": name}}
+	default:
+		return choice
+	}
+}
