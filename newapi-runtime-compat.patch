+        title={t('Delete User-Agent')}
+        desc={t('Delete this User-Agent entry?')}
+        confirmText={t('Delete')}
+        destructive
+        isLoading={deleteMutation.isPending}
+        handleConfirm={() => deleteTarget && deleteMutation.mutate(deleteTarget.id)}
+      />
+    </SettingsSection>
+  )
+}
