+  },
+  {
+    value: 'centered',
+    label: 'Centered',
+    description: 'Constrain content width for a quieter reading layout.',
+  },
+]
+
+export function AppearanceSettings({ defaultValues }: AppearanceSettingsProps) {
+  const { t } = useTranslation()
