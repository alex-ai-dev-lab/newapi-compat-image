+func initClaudeThinkingCompat(c *gin.Context, info *relaycommon.RelayInfo) {
+	if c == nil || info == nil || info.RelayFormat != types.RelayFormatClaude {
+		return
+	}
+	req, ok := info.Request.(*dto.ClaudeRequest)
