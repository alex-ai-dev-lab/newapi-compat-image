+                      <TableCell className='text-right tabular-nums'>
+                        {formatUsd(model.total_cost)}
+                      </TableCell>
+                    </TableRow>
+                  ))
+                )}
+              </TableBody>
+            </Table>
+          </div>
+          {!isLoading && filteredRows.length > 0 ? (
+            <div className='flex flex-col gap-3 border-t p-3 sm:flex-row sm:items-center sm:justify-between'>
