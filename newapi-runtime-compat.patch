+const contentLayoutValues = Array.from(CONTENT_LAYOUT_VALUES) as [
+  ContentLayout,
+  ...ContentLayout[],
+]
+
+const appearanceSchema = z.object({
+  theme: z.object({
+    customization_preset: z.enum(themePresetValues),
