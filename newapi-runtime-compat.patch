+func getChannelNameMap(ids []int) map[int]string {
+	names := map[int]string{}
+	if len(ids) == 0 {
+		return names
+	}
+	type row struct {
+		ID   int
+		Name string
+	}
+	var rows []row
+	if err := DB.Table("channels").Select("id, name").Where("id IN ?", ids).Scan(&rows).Error; err != nil {
+		return names
+	}
+	for _, r := range rows {
+		names[r.ID] = r.Name
+	}
+	return names
+}
