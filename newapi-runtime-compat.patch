+func SanitizeClaudeToolInput(toolName string, input any) any {
+	if !isClaudeReadTool(toolName) {
+		return input
+	}
+
+	var parsed map[string]any
+	switch v := input.(type) {
+	case map[string]any:
+		parsed = make(map[string]any, len(v))
+		for key, value := range v {
+			parsed[key] = value
+		}
+	default:
+		data, err := common.Marshal(input)
+		if err != nil || common.Unmarshal(data, &parsed) != nil {
+			return input
+		}
+	}
+
+	if value, ok := parsed["pages"]; ok {
+		deletePages := false
+		switch v := value.(type) {
+		case nil:
+			deletePages = true
+		case string:
+			deletePages = strings.TrimSpace(v) == "" || !isClaudeReadPDFTarget(parsed)
+		default:
+			deletePages = !isClaudeReadPDFTarget(parsed)
+		}
+		if deletePages {
+			delete(parsed, "pages")
+		}
+	}
+
+	return parsed
+}
+
+func isClaudeReadPDFTarget(input map[string]any) bool {
+	for _, key := range []string{"file_path", "path"} {
+		value, ok := input[key]
+		if !ok {
+			continue
+		}
+		if strings.HasSuffix(strings.ToLower(strings.TrimSpace(common.Interface2String(value))), ".pdf") {
+			return true
+		}
+	}
+	return false
+}
+
+func SanitizeClaudeToolArgumentsJSON(toolName string, args string) string {
+	if strings.TrimSpace(args) == "" {
+		return args
+	}
+	var parsed map[string]any
+	if err := common.Unmarshal([]byte(args), &parsed); err != nil {
+		return args
+	}
+	sanitized := SanitizeClaudeToolInput(toolName, parsed)
+	data, err := common.Marshal(sanitized)
+	if err != nil {
+		return args
+	}
+	return string(data)
+}
+
+func isClaudeReadTool(toolName string) bool {
+	return strings.EqualFold(strings.TrimSpace(toolName), "Read")
+}
+
+func mergeConsecutiveAssistantToolUseMessages(messages []dto.Message) []dto.Message {
+	if len(messages) < 2 {
+		return messages
+	}
+	merged := make([]dto.Message, 0, len(messages))
+	for _, message := range messages {
+		if len(merged) > 0 && isAssistantToolOnlyMessage(merged[len(merged)-1]) && isAssistantToolOnlyMessage(message) {
+			toolCalls := append(merged[len(merged)-1].ParseToolCalls(), message.ParseToolCalls()...)
+			merged[len(merged)-1].SetToolCalls(toolCalls)
+			continue
+		}
+		merged = append(merged, message)
+	}
+	return merged
+}
+
+func isAssistantToolOnlyMessage(message dto.Message) bool {
+	return message.Role == "assistant" && message.Content == nil && len(message.ParseToolCalls()) > 0
+}
