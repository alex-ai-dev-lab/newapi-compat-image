+                      direction={modelSort.direction}
+                      onClick={() => setModelSort(nextSortState(modelSort, 'failures'))}
+                    />
+                  </TableHead>
+                  <TableHead className='text-right'>
+                    <SortableHeader
+                      label='Success'
+                      align='right'
+                      active={modelSort.key === 'success'}
+                      direction={modelSort.direction}
+                      onClick={() => setModelSort(nextSortState(modelSort, 'success'))}
+                    />
+                  </TableHead>
+                  <TableHead className='text-right'>
+                    <SortableHeader
+                      label='First token'
+                      align='right'
+                      active={modelSort.key === 'first_token'}
+                      direction={modelSort.direction}
+                      onClick={() => setModelSort(nextSortState(modelSort, 'first_token'))}
