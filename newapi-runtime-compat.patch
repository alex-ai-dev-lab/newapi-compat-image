+                  </TableHead>
+                  <TableHead className='text-right'>
+                    <SortableHeader
+                      label='首 token'
+                      align='right'
+                      active={modelSort.key === 'first_token'}
+                      direction={modelSort.direction}
+                      onClick={() =>
+                        setModelSort(nextSortState(modelSort, 'first_token'))
+                      }
+                    />
+                  </TableHead>
+                  <TableHead className='text-right'>
+                    <SortableHeader
+                      label='耗时'
+                      align='right'
+                      active={modelSort.key === 'use_time'}
+                      direction={modelSort.direction}
+                      onClick={() =>
