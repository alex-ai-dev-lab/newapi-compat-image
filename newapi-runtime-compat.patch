+func sanitizeClaudeCodeAttributionHeader(c *gin.Context, request *dto.ClaudeRequest) {
+	if request == nil || request.System == nil {
+		return
+	}
+	cleanSystem, changed := sanitizeClaudeCodeAttributionHeaderSystem(request.System)
+	if !changed {
+		return
+	}
+	request.System = cleanSystem
+	if c == nil {
+		return
+	}
+	body, err := common.Marshal(request)
+	if err != nil {
+		return
+	}
+	newStorage, err := common.CreateBodyStorage(body)
+	if err != nil {
+		return
+	}
+	if existing, ok := c.Get(common.KeyBodyStorage); ok {
+		if oldStorage, ok := existing.(common.BodyStorage); ok {
+			_ = oldStorage.Close()
+		}
+	}
+	c.Set(common.KeyBodyStorage, newStorage)
+	c.Request.ContentLength = int64(len(body))
+}
+
+func sanitizeClaudeCodeAttributionHeaderSystem(system any) (any, bool) {
+	switch typed := system.(type) {
+	case string:
+		cleaned, changed := stripClaudeCodeAttributionHeaderText(typed)
+		if !changed {
+			return system, false
+		}
+		if strings.TrimSpace(cleaned) == "" {
+			return nil, true
+		}
+		return cleaned, true
+	case []dto.ClaudeMediaMessage:
+		return sanitizeClaudeCodeAttributionHeaderMedia(typed)
+	default:
+		media, err := common.Any2Type[[]dto.ClaudeMediaMessage](system)
+		if err != nil {
+			return system, false
+		}
+		return sanitizeClaudeCodeAttributionHeaderMedia(media)
+	}
+}
+
+func sanitizeClaudeCodeAttributionHeaderMedia(system []dto.ClaudeMediaMessage) (any, bool) {
+	cleaned := make([]dto.ClaudeMediaMessage, 0, len(system))
+	changed := false
+	for _, item := range system {
+		if item.Type == "" || item.Type == dto.ContentTypeText {
+			text := item.GetText()
+			stripped, textChanged := stripClaudeCodeAttributionHeaderText(text)
+			if textChanged {
+				changed = true
+				if strings.TrimSpace(stripped) == "" {
+					continue
+				}
+				item.SetText(stripped)
+			}
+		}
+		cleaned = append(cleaned, item)
+	}
+	if !changed {
+		return system, false
+	}
+	if len(cleaned) == 0 {
+		return nil, true
+	}
+	return cleaned, true
+}
+
+func stripClaudeCodeAttributionHeaderText(text string) (string, bool) {
+	if !strings.Contains(text, "x-anthropic-billing-header:") {
+		return text, false
+	}
+	lines := strings.Split(text, "\n")
+	kept := make([]string, 0, len(lines))
+	changed := false
+	for _, line := range lines {
+		trimmed := strings.TrimSpace(line)
+		if strings.HasPrefix(trimmed, "x-anthropic-billing-header:") &&
+			(strings.Contains(trimmed, "cch=") ||
+				strings.Contains(trimmed, "cc_version=") ||
+				strings.Contains(trimmed, "cc_entrypoint=")) {
+			changed = true
+			continue
+		}
+		kept = append(kept, line)
+	}
+	if !changed {
+		return text, false
+	}
+	return strings.TrimSpace(strings.Join(kept, "\n")), true
+}
