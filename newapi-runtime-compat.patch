+func resolveDefaultUpstreamUserAgent(info *common.RelayInfo, req *http.Request) string {
+	if info == nil || req == nil || req.URL == nil {
+		return ""
+	}
+
+	path := strings.ToLower(strings.TrimSpace(req.URL.Path))
+	if info.RelayFormat == types.RelayFormatClaude ||
+		strings.HasSuffix(path, "/v1/messages") ||
+		strings.Contains(path, "/anthropic/v1/messages") ||
+		req.Header.Get("anthropic-version") != "" {
+		return defaultClaudeCLIUserAgent
+	}
+
+	if info.RelayFormat == types.RelayFormatOpenAI ||
+		info.RelayFormat == types.RelayFormatOpenAIResponses ||
+		info.RelayFormat == types.RelayFormatOpenAIResponsesCompaction ||
+		info.RelayFormat == types.RelayFormatEmbedding ||
+		info.RelayFormat == types.RelayFormatOpenAIImage ||
+		strings.Contains(path, "/v1/chat/completions") ||
+		strings.Contains(path, "/v1/completions") ||
+		strings.Contains(path, "/v1/responses") ||
+		strings.Contains(path, "/v1/embeddings") ||
+		strings.Contains(path, "/v1/images") ||
+		strings.Contains(path, "/backend-api/codex/responses") {
+		return defaultCodexCLIUserAgent
+	}
+
+	return ""
+}
+
+// resolveUserAgentCategory maps the relay format/path to a model category used
+// by the custom UA list feature.
+func resolveUserAgentCategory(info *common.RelayInfo, req *http.Request) string {
+	if info == nil || req == nil || req.URL == nil {
+		return model.ModelCategoryOther
+	}
+	modelName := strings.ToLower(strings.TrimSpace(info.OriginModelName))
+	upstreamModelName := strings.ToLower(strings.TrimSpace(info.UpstreamModelName))
+	combinedModelName := modelName + " " + upstreamModelName
+	if strings.Contains(combinedModelName, "claude") {
+		return model.ModelCategoryClaude
+	}
+	if strings.Contains(combinedModelName, "grok") || strings.Contains(combinedModelName, "xai") {
+		return model.ModelCategoryGrok
+	}
+	if strings.Contains(combinedModelName, "gemini") {
+		return model.ModelCategoryGemini
+	}
+	path := strings.ToLower(strings.TrimSpace(req.URL.Path))
+	if info.RelayFormat == types.RelayFormatClaude ||
+		strings.HasSuffix(path, "/v1/messages") ||
+		strings.Contains(path, "/anthropic/v1/messages") ||
+		req.Header.Get("anthropic-version") != "" {
+		return model.ModelCategoryClaude
+	}
+	if strings.Contains(path, "/v1/responses") ||
+		strings.Contains(path, "/backend-api/codex/responses") ||
+		info.RelayFormat == types.RelayFormatOpenAIResponses ||
+		info.RelayFormat == types.RelayFormatOpenAIResponsesCompaction {
+		return model.ModelCategoryOpenAI
+	}
+	if info.ChannelType == rootconstant.ChannelTypeGemini {
+		return model.ModelCategoryGemini
+	}
+	if info.ChannelType == rootconstant.ChannelTypeXai {
+		return model.ModelCategoryGrok
+	}
+	if info.RelayFormat == types.RelayFormatOpenAI ||
+		info.RelayFormat == types.RelayFormatEmbedding ||
+		info.RelayFormat == types.RelayFormatOpenAIImage ||
+		strings.Contains(path, "/v1/chat/completions") ||
+		strings.Contains(path, "/v1/completions") ||
+		strings.Contains(path, "/v1/embeddings") ||
+		strings.Contains(path, "/v1/images") {
+		return model.ModelCategoryOpenAI
+	}
+	return model.ModelCategoryOther
+}
+
+// resolveCustomUpstreamUserAgent resolves a UA from the custom UA list feature.
+// Precedence: channel inline override -> channel-selected UA id -> global UA by
+// model category. Returns "" when none is configured, so the caller can fall
+// back to the built-in CLI defaults.
+func resolveCustomUpstreamUserAgent(info *common.RelayInfo, req *http.Request) string {
+	if info == nil {
+		return ""
+	}
+	if ua := strings.TrimSpace(info.ChannelSetting.UserAgentOverride); ua != "" {
+		return ua
+	}
+	if info.ChannelSetting.UserAgentID != nil {
+		if ua, ok := model.GetCachedUserAgentByID(*info.ChannelSetting.UserAgentID); ok {
+			if ua = strings.TrimSpace(ua); ua != "" {
+				return ua
+			}
+		}
+	}
+	category := resolveUserAgentCategory(info, req)
+	if ua, ok := model.GetCachedGlobalUserAgent(category); ok {
+		if ua = strings.TrimSpace(ua); ua != "" {
+			return ua
+		}
+	}
+	return ""
+}
+
+func applyDefaultUpstreamUserAgent(req *http.Request, info *common.RelayInfo) {
+	if req == nil {
+		return
+	}
+	if strings.TrimSpace(req.Header.Get("User-Agent")) != "" {
+		return
+	}
+	// Custom UA list (channel override / channel-selected / global-by-category)
+	// wins over the built-in CLI defaults.
+	if ua := resolveCustomUpstreamUserAgent(info, req); ua != "" {
+		req.Header.Set("User-Agent", ua)
+		return
+	}
+	userAgent := resolveDefaultUpstreamUserAgent(info, req)
+	if userAgent == "" {
+		return
+	}
+	req.Header.Set("User-Agent", userAgent)
+}
+
+func applyManagedUpstreamUserAgent(req *http.Request, info *common.RelayInfo) {
+	if req == nil {
+		return
+	}
+	ua := resolveCustomUpstreamUserAgent(info, req)
+	if ua == "" {
+		return
+	}
+	req.Header.Set("User-Agent", ua)
+}
