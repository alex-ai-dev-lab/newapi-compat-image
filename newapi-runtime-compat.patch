+	if marshalErr != nil {
+		return nil, types.NewOpenAIError(marshalErr, types.ErrorCodeJsonMarshalFailed, http.StatusInternalServerError)
+	}
+	c.Header("Content-Type", "application/json; charset=utf-8")
