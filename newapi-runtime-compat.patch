+func stripOpenAIStreamResponseProof(data string, proof *antipoison.ProofStreamValidator) (string, bool, error) {
+	if proof == nil || proof.Verified() || data == "" {
+		return data, false, nil
+	}
+	var chunk dto.ChatCompletionsStreamResponse
+	if err := common.UnmarshalJsonStr(data, &chunk); err != nil {
+		return data, true, err
+	}
+	changed := false
+	for i := range chunk.Choices {
+		delta := &chunk.Choices[i].Delta
+		if delta.Content == nil {
+			continue
+		}
+		cleaned, hold, err := proof.ProcessText(delta.GetContentString())
+		if err != nil {
+			return "", true, err
+		}
+		if hold {
+			return "", true, nil
+		}
+		delta.SetContentString(cleaned)
+		changed = true
+	}
+	if !changed && !proof.Verified() {
+		return data, false, nil
+	}
+	if !changed {
+		return data, false, nil
+	}
+	b, err := common.Marshal(chunk)
+	if err != nil {
+		return data, false, err
+	}
+	return string(b), false, nil
+}
+
+func openAIStreamChunkHasVisibleText(data string) bool {
+	if data == "" {
+		return false
+	}
+	var chunk dto.ChatCompletionsStreamResponse
+	if err := common.UnmarshalJsonStr(data, &chunk); err != nil {
+		return false
+	}
+	for _, choice := range chunk.Choices {
+		if strings.TrimSpace(choice.Delta.GetContentString()) != "" {
+			return true
+		}
+	}
+	return false
+}
