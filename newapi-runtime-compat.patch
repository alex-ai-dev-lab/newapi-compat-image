+            <FormControl>
+              <Input
+                {...field}
+                disabled={props.disabled}
+                placeholder={props.fallback}
+                className='font-mono'
+              />
+            </FormControl>
+            <Input
+              type='color'
+              value={
+                /^#[0-9a-fA-F]{6}$/.test(props.previewValue)
+                  ? props.previewValue
