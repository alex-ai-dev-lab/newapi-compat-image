+  align-items: center;
+  gap: 0.5rem;
+  padding: 0.5rem 0.5rem 0.5rem 0.75rem;
+  border: 1px solid var(--iz-line-strong);
+  border-radius: 0.7rem;
+  background: var(--iz-surface);
+  backdrop-filter: blur(10px);
+  font-family: var(--iz-mono);
+  font-size: 12.5px;
+  box-shadow: 0 1px 0 color-mix(in oklab, var(--foreground) 6%, transparent) inset,
+    0 8px 30px -16px color-mix(in oklab, var(--foreground) 30%, transparent);
+}
+.iz-hero-base-label {
+  color: var(--iz-fg-muted);
+  letter-spacing: 0.1em;
+  font-size: 10px;
+  text-transform: uppercase;
+}
+.iz-hero-base-url {
+  color: var(--iz-fg);
+  max-width: 18rem;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.iz-hero-base-mount {
+  display: inline-flex;
+  align-items: baseline;
+  gap: 0.2rem;
+  padding: 0.2rem 0.55rem;
+  border-radius: 0.45rem;
+  background: color-mix(in oklab, var(--foreground) 7%, transparent);
+  color: var(--iz-fg);
+  min-width: 13rem;
+  justify-content: flex-start;
+  overflow: hidden;
+}
+.iz-hero-base-mount-prefix {
+  color: var(--iz-fg-muted);
+}
+.iz-hero-base-mount-path {
+  display: inline-block;
+  animation: iz-slot 350ms cubic-bezier(0.16, 1, 0.3, 1);
+}
+.iz-hero-base-copy {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 1.85rem;
+  height: 1.85rem;
+  border-radius: 0.45rem;
+  border: 1px solid transparent;
+  background: transparent;
+  color: var(--iz-fg-soft);
+  transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease;
+}
+.iz-hero-base-copy:hover {
+  background: color-mix(in oklab, var(--foreground) 8%, transparent);
+  color: var(--iz-fg);
+  border-color: var(--iz-line);
+}
+
+.iz-hero-cta {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.65rem;
+  margin-top: 1rem;
+  animation: iz-fade-in 900ms 750ms cubic-bezier(0.16, 1, 0.3, 1) both;
+}
+
+.iz-hero-stats {
+  display: inline-flex;
+  align-items: center;
+  gap: 1.25rem;
+  margin-top: 2.25rem;
+  padding: 0.65rem 1.25rem;
+  border: 1px solid var(--iz-line);
+  border-radius: 999px;
+  background: var(--iz-surface);
+  backdrop-filter: blur(10px);
+  animation: iz-fade-in 900ms 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
+}
+.iz-hero-stat {
+  display: inline-flex;
+  flex-direction: column;
+  align-items: flex-start;
+  line-height: 1.1;
+}
+.iz-hero-stat-num {
+  font-family: var(--iz-mono);
+  font-size: 0.95rem;
+  color: var(--iz-fg);
+  font-feature-settings: 'tnum' 1;
+}
+.iz-hero-stat-num i {
+  font-style: normal;
+  color: var(--iz-fg-muted);
+  margin-left: 0.1rem;
+  font-size: 0.75rem;
+}
+.iz-hero-stat-lbl {
+  margin-top: 0.15rem;
+  font-size: 10.5px;
+  color: var(--iz-fg-muted);
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+}
+.iz-hero-stat-sep {
+  width: 1px;
+  height: 22px;
+  background: var(--iz-line);
+}
+
+.iz-hero-scroll {
+  position: absolute;
+  bottom: 1.5rem;
+  left: 50%;
+  transform: translateX(-50%);
+  width: 1px;
+  height: 38px;
+  overflow: hidden;
+  background: var(--iz-line);
+}
+.iz-hero-scroll span {
+  display: block;
+  width: 100%;
+  height: 30%;
+  background: var(--iz-fg);
+  animation: iz-scroll 2.2s cubic-bezier(0.65, 0, 0.35, 1) infinite;
+}
+
+/* ── PILLARS ── */
+.iz-pillars {
+  position: relative;
+  padding: 6rem 1.25rem;
+  border-top: 1px solid var(--iz-line);
+}
+.iz-pillars-inner {
+  max-width: 76rem;
+  margin: 0 auto;
+}
+.iz-pillar-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
+  gap: 0;
+  border: 1px solid var(--iz-line);
+  border-radius: 1rem;
+  overflow: hidden;
+  background: var(--iz-surface);
+}
+.iz-pillar-cell {
+  border-right: 1px solid var(--iz-line);
+  border-bottom: 1px solid var(--iz-line);
+}
+.iz-pillar-cell:nth-child(4n),
+.iz-pillar-cell:last-child {
+  border-right: none;
+}
+.iz-pillar {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  gap: 0.85rem;
+  padding: 1.6rem 1.4rem 1.5rem;
+  height: 100%;
+  background: var(--iz-bg);
+  transition: background-color 240ms ease;
+  overflow: hidden;
+}
+.iz-pillar:hover {
+  background: var(--iz-surface-2);
+}
+.iz-pillar-icon {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 2rem;
+  height: 2rem;
+  border: 1px solid var(--iz-line);
+  border-radius: 0.55rem;
+  background: var(--iz-surface);
+  color: var(--iz-fg);
+}
+.iz-pillar-title {
+  margin: 0;
+  font-size: 0.975rem;
+  font-weight: 600;
+  letter-spacing: -0.01em;
+  color: var(--iz-fg);
+}
+.iz-pillar-desc {
+  margin: 0;
+  font-size: 0.84rem;
+  line-height: 1.6;
+  color: var(--iz-fg-muted);
+}
+.iz-pillar-meta {
+  margin-top: auto;
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  letter-spacing: 0.06em;
+  color: var(--iz-fg-soft);
+}
+.iz-pillar-glow {
+  position: absolute;
+  inset: auto -40% -60% auto;
+  width: 60%;
+  height: 60%;
+  background: radial-gradient(closest-side, var(--iz-glow), transparent);
+  opacity: 0;
+  transition: opacity 320ms ease;
+  pointer-events: none;
+  filter: blur(20px);
+}
+.iz-pillar:hover .iz-pillar-glow {
+  opacity: 0.35;
+}
+
+/* ── ENDPOINTS ── */
+.iz-endpoints {
+  position: relative;
+  padding: 6rem 1.25rem;
+  border-top: 1px solid var(--iz-line);
+}
+.iz-endpoints-inner {
+  max-width: 76rem;
+  margin: 0 auto;
+}
+.iz-endpoint-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
+  gap: 0.85rem;
+}
+.iz-endpoint {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  gap: 0.65rem;
+  padding: 1.15rem 1.15rem 1rem;
+  border: 1px solid var(--iz-line);
+  border-radius: 0.85rem;
+  background: var(--iz-surface);
+  transition: transform 240ms ease, border-color 240ms ease, background-color 240ms ease;
+}
+.iz-endpoint:hover {
+  transform: translateY(-2px);
+  border-color: var(--iz-line-strong);
+  background: var(--iz-surface-2);
+}
+.iz-endpoint-head {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  min-width: 0;
+}
+.iz-endpoint-method {
+  font-family: var(--iz-mono);
+  font-size: 10.5px;
+  letter-spacing: 0.08em;
+  padding: 0.18rem 0.4rem;
+  border-radius: 0.35rem;
+  background: var(--iz-fg);
+  color: var(--iz-bg);
+  flex-shrink: 0;
+}
+.iz-endpoint-path {
+  font-family: var(--iz-mono);
+  font-size: 0.83rem;
+  color: var(--iz-fg);
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.iz-endpoint-desc {
+  margin: 0;
+  font-size: 0.83rem;
+  line-height: 1.55;
+  color: var(--iz-fg-muted);
+}
+.iz-endpoint-foot {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  margin-top: 0.25rem;
+  padding-top: 0.6rem;
+  border-top: 1px dashed var(--iz-line);
+}
+.iz-endpoint-tag {
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  color: var(--iz-fg-soft);
+}
+.iz-endpoint-status {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.35rem;
+  font-family: var(--iz-mono);
+  font-size: 10.5px;
+  color: var(--iz-fg-muted);
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+}
+.iz-endpoint-status-dot {
+  width: 5px;
+  height: 5px;
+  border-radius: 999px;
+  background: #22c55e;
+  box-shadow: 0 0 0 3px color-mix(in oklab, #22c55e 25%, transparent);
+  animation: iz-pulse 2.4s ease-in-out infinite;
+}
+
+/* ── QUICKSTART (code block) ── */
+.iz-quickstart {
+  position: relative;
+  padding: 6rem 1.25rem;
+  border-top: 1px solid var(--iz-line);
+}
+.iz-quickstart-inner {
+  max-width: 60rem;
+  margin: 0 auto;
+}
+.iz-code {
+  border: 1px solid var(--iz-line);
+  border-radius: 0.95rem;
+  background: var(--iz-bg);
+  box-shadow: 0 24px 60px -28px color-mix(in oklab, var(--foreground) 30%, transparent),
+    0 1px 0 color-mix(in oklab, var(--foreground) 5%, transparent) inset;
+  overflow: hidden;
+}
+.iz-code-bar {
+  display: flex;
+  align-items: center;
+  gap: 0.75rem;
+  padding: 0.65rem 0.75rem;
+  border-bottom: 1px solid var(--iz-line);
+  background: var(--iz-surface);
+}
+.iz-code-dots {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.35rem;
+  flex-shrink: 0;
+}
+.iz-code-dots span {
+  width: 10px;
+  height: 10px;
+  border-radius: 999px;
+  background: var(--iz-line-strong);
+}
+.iz-code-tabs {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.15rem;
+  margin: 0 auto 0 0.5rem;
+}
+.iz-code-tab {
+  font-family: var(--iz-mono);
+  font-size: 11.5px;
+  letter-spacing: 0.02em;
+  padding: 0.32rem 0.6rem;
+  border-radius: 0.4rem;
+  border: 1px solid transparent;
+  background: transparent;
+  color: var(--iz-fg-muted);
+  cursor: pointer;
+  transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease;
+}
+.iz-code-tab:hover {
+  color: var(--iz-fg);
+}
+.iz-code-tab.is-active {
+  color: var(--iz-fg);
+  background: var(--iz-bg);
+  border-color: var(--iz-line);
+}
+.iz-code-copy {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.35rem;
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  letter-spacing: 0.04em;
+  padding: 0.32rem 0.55rem;
+  border-radius: 0.4rem;
+  border: 1px solid var(--iz-line);
+  background: var(--iz-bg);
+  color: var(--iz-fg-soft);
+  cursor: pointer;
+  transition: color 160ms ease, background-color 160ms ease;
+}
+.iz-code-copy:hover {
+  color: var(--iz-fg);
+  background: var(--iz-surface);
+}
+.iz-code-body {
+  margin: 0;
+  padding: 1.25rem 1.25rem;
+  font-family: var(--iz-mono);
+  font-size: 12.5px;
+  line-height: 1.7;
+  color: var(--iz-fg);
+  overflow-x: auto;
+  white-space: pre;
+  tab-size: 2;
+}
+.iz-code-foot {
+  display: flex;
+  align-items: center;
+  gap: 0.45rem;
+  padding: 0.55rem 0.95rem;
+  border-top: 1px solid var(--iz-line);
+  background: var(--iz-surface);
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  color: var(--iz-fg-muted);
+}
+.iz-code-foot-dot {
+  width: 5px;
+  height: 5px;
+  border-radius: 999px;
+  background: #22c55e;
+}
+
+/* ── CLOSING ── */
+.iz-closing {
+  position: relative;
+  padding: 7rem 1.25rem 8rem;
+  border-top: 1px solid var(--iz-line);
+  overflow: hidden;
+  isolation: isolate;
+}
+.iz-closing-bg,
+.iz-closing-grid {
+  position: absolute;
+  inset: 0;
+  pointer-events: none;
+}
+.iz-closing-bg {
+  background: radial-gradient(
+    80% 80% at 50% 50%,
+    color-mix(in oklab, var(--foreground) 8%, transparent),
+    transparent 70%
+  );
+  z-index: -2;
+}
+.iz-closing-grid {
+  background-image:
+    linear-gradient(to right, var(--iz-line) 1px, transparent 1px),
+    linear-gradient(to bottom, var(--iz-line) 1px, transparent 1px);
+  background-size: 48px 48px;
+  mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 70%);
+  -webkit-mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 70%);
+  opacity: 0.55;
+  z-index: -1;
+}
+.iz-closing-inner {
+  max-width: 40rem;
+  margin: 0 auto;
+  text-align: center;
+}
+.iz-closing-kicker {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.5rem;
+  padding: 0.3rem 0.7rem;
+  border: 1px solid var(--iz-line);
+  border-radius: 999px;
+  font-family: var(--iz-mono);
+  font-size: 11px;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+  color: var(--iz-fg-soft);
+  background: var(--iz-surface);
+}
+.iz-closing-kicker-dot {
+  width: 5px;
+  height: 5px;
+  border-radius: 999px;
+  background: var(--iz-fg);
+}
+.iz-closing-title {
+  margin: 1rem 0 0.85rem;
+  font-size: clamp(1.85rem, 3.2vw, 2.65rem);
+  line-height: 1.12;
+  letter-spacing: -0.025em;
+  font-weight: 600;
+  color: var(--iz-fg);
+}
+.iz-closing-sub {
+  margin: 0 0 1.5rem;
+  font-size: 0.975rem;
+  line-height: 1.65;
+  color: var(--iz-fg-muted);
+}
+.iz-closing-cta {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.65rem;
+}
+
+/* ── Keyframes ── */
+@keyframes iz-rise {
+  to {
+    transform: translateY(0);
+  }
+}
+@keyframes iz-fade-in {
+  from {
+    opacity: 0;
+    transform: translateY(8px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+@keyframes iz-eyebrow-in {
+  from {
+    opacity: 0;
+    transform: translateY(-8px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+@keyframes iz-pulse {
+  0%,
+  100% {
+    opacity: 1;
+  }
+  50% {
+    opacity: 0.5;
+  }
+}
+@keyframes iz-slot {
+  from {
+    transform: translateY(120%);
+    opacity: 0;
+  }
+  to {
+    transform: translateY(0);
+    opacity: 1;
+  }
+}
+@keyframes iz-scroll {
+  0% {
+    transform: translateY(-100%);
+  }
+  50% {
+    transform: translateY(120%);
+  }
+  100% {
+    transform: translateY(120%);
+  }
+}
+
+@media (max-width: 640px) {
+  .iz-hero {
+    padding-top: 6rem;
+    min-height: auto;
+  }
+  .iz-hero-base-frame {
+    flex-wrap: wrap;
+    gap: 0.4rem;
+  }
+  .iz-hero-base-url {
+    max-width: 100%;
+  }
+  .iz-hero-base-mount {
+    min-width: 0;
+  }
+  .iz-hero-stats {
+    gap: 0.85rem;
+    padding: 0.55rem 0.95rem;
+  }
+  .iz-pillar-cell {
+    border-right: none !important;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .iz-hero-title-word,
+  .iz-hero-title-accent,
+  .iz-hero-title-glow,
+  .iz-hero-eyebrow,
+  .iz-hero-sub,
+  .iz-hero-base,
+  .iz-hero-cta,
+  .iz-hero-stats,
+  .iz-hero-base-mount-path,
+  .iz-hero-scroll span,
+  .iz-hero-dot,
+  .iz-endpoint-status-dot {
+    animation: none !important;
+    transform: none !important;
+    opacity: 1 !important;
+  }
+}
